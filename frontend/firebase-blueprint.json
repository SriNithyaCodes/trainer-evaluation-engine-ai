{
  "entities": {
    "Trainer": {
      "title": "Trainer",
      "description": "User profile with trainer-specific metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "organization": { "type": "string" },
        "specialization": { "type": "string" },
        "dnaType": { "type": "string", "enum": ["Motivator", "Storyteller", "Technical Expert", "Interactive Coach", "Fast Lecturer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "Session": {
      "title": "Session",
      "description": "A recorded training session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "trainerId": { "type": "string" },
        "title": { "type": "string" },
        "transcript": { "type": "string" },
        "duration": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["trainerId", "title", "transcript"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "AI-generated autopsy of a session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "trainerId": { "type": "string" },
        "clarityScore": { "type": "number" },
        "engagementScore": { "type": "number" },
        "confidenceScore": { "type": "number" },
        "pacingScore": { "type": "number" },
        "energyLevel": { "type": "number" },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "sentimentTimeline": { "type": "array", "items": { "type": "object" } }
      }
    }
  },
  "firestore": {
    "/trainers/{trainerId}": {
      "schema": "Trainer",
      "description": "Public and private trainer profile info"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Metadata and transcripts for training sessions"
    },
    "/analysis/{analysisId}": {
      "schema": "Analysis",
      "description": "Detailed AI evaluation results"
    }
  }
}
