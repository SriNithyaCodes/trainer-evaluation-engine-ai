rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /trainers/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (resource.data.trainerId == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.trainerId == request.auth.uid);
      allow update, delete: if isSignedIn() && (resource.data.trainerId == request.auth.uid);
    }

    match /analysis/{analysisId} {
      allow read: if isSignedIn() && (resource.data.trainerId == request.auth.uid);
      allow create, update: if isSignedIn() && (request.resource.data.trainerId == request.auth.uid);
    }
  }
}
